# J.A.R.V.I.S Environment Variables
# Copy to .env and fill in your API keys

# ══════════════════════════════════════════════════════
#  LLM API KEYS — Add your preferred provider
# ══════════════════════════════════════════════════════

# Google Gemini (recommended — free tier available)
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI GPT-4 (optional)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic Claude (optional)
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# NVIDIA NIM (optional — OpenAI-compatible, Llama/Mixtral models)
# Get key at: https://build.nvidia.com/
NVIDIA_API_KEY=

# ══════════════════════════════════════════════════════
#  LLM SETTINGS
# ══════════════════════════════════════════════════════
# Which LLM to use: gemini | openai | claude | nvidia | none
LLM_PROVIDER=gemini

# Model to use (leave blank for default)
LLM_MODEL=gemini-2.0-flash

# ══════════════════════════════════════════════════════
#  VOICE SETTINGS
# ══════════════════════════════════════════════════════
# Enable voice output (text-to-speech)
VOICE_ENABLED=true

# TTS Voice (British male like JARVIS)
# Options: en-GB-RyanNeural | en-GB-SoniaNeural | en-US-GuyNeural
TTS_VOICE=en-GB-RyanNeural

# TTS speed (0.5 = slow, 1.0 = normal, 1.3 = fast)
TTS_RATE=+20%

# ══════════════════════════════════════════════════════
#  SYSTEM
# ══════════════════════════════════════════════════════
JARVIS_SECRET_KEY=jarvis-ultra-secret-key-change-me
FLASK_SECRET_KEY=flask-secret-key-change-me
JARVIS_DEBUG=false
